{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OfficeAgent": {
    "Transport": "http",
    "AllowRegistration": true,
    "FileSystemConnections": [
      {
        "ConnectionId": "documents",
        "RootPath": "./documents",
        "MaximumBytes": 104857600,
        "AllowedExtensions": [ ".docx" ]
      }
    ],
    "SharePointConnections": []
  }
}
